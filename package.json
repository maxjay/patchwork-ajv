{
  "name": "@maxjay/patchwork-ajv",
  "version": "0.5.0",
  "description": "AJV JSON Schema validation for patchwork Engine/NodeEngine drafts.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "peerDependencies": {
    "@maxjay/patchwork": ">=0.18.0"
  },
  "peerDependenciesMeta": {
    "@maxjay/patchwork": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maxjay/patchwork-ajv"
  },
  "publishConfig": {
    "access": "public"
  }
}
